wordpressScheme: https

ingress:
  hostname: 'ref+awsssm://{{ .Environment.Values.cluster_name }}/blog-fqdn?region={{ .Environment.Values.region }}'
  annotations:
    alb.ingress.kubernetes.io/certificate-arn: 'ref+awsssm://{{ .Environment.Values.cluster_name }}/certificate-arn?region={{ .Environment.Values.region }}'
    alb.ingress.kubernetes.io/group.name: wordpress
